rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentRole() {
      return userExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'customer';
    }

    // Keep this matrix synchronized with config/rbac.json. CI validates the JSON
    // source; Firestore remains the final authorization boundary for browser calls.
    function hasPermission(permission) {
      return signedIn() && (
        currentRole() == 'admin'
        || (
          currentRole() == 'analyst'
          && permission in [
            'dashboard.access',
            'projects.read',
            'inventory.read',
            'equipment.read',
            'analytics.read'
          ]
        )
        || (
          currentRole() == 'inventory_manager'
          && permission in [
            'dashboard.access',
            'inventory.read',
            'inventory.write',
            'equipment.read',
            'equipment.write'
          ]
        )
        || (
          currentRole() == 'project_manager'
          && permission in [
            'dashboard.access',
            'projects.read',
            'projects.create',
            'projects.update',
            'projects.payments',
            'projects.documents',
            'notifications.send'
          ]
        )
      );
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validNewProject(projectId) {
      return projectId == request.resource.data.projectId
        && request.resource.data.status == 'quote_pending'
        && request.resource.data.paymentStatus == 'not_started'
        && request.resource.data.panelCount is number
        && request.resource.data.panelCount > 0
        && request.resource.data.quotedPrice is number
        && request.resource.data.quotedPrice > 0;
    }

    function projectIdentityUnchanged() {
      return request.resource.data.projectId == resource.data.projectId
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function operationalProjectFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'updatedAt',
        'adminNotes',
        'technicalNotes',
        'sitePhotos',
        'techniciansAssigned',
        'customerSignoff',
        'completionNotes',
        'finalPrice',
        'quoteSentDate',
        'approvalDate',
        'advanceAmount',
        'balanceAmount',
        'installationScheduledDate',
        'installationStartDate',
        'completionDate'
      ]);
    }

    function paymentProjectFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'paymentStatus',
        'paymentHistory',
        'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || hasPermission('users.read');
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'customer';
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email', 'displayName', 'updatedAt'
        ]);

      // Role administration uses the authenticated Netlify function. Firebase
      // Admin bypasses these rules and writes an audit record atomically.
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow read: if hasPermission('projects.read') || (
        signedIn() && resource.data.customerId == request.auth.uid
      );
      allow create: if validNewProject(projectId) && (
        hasPermission('projects.create') || (
          signedIn() && request.resource.data.customerId == request.auth.uid
        )
      );
      allow update: if projectIdentityUnchanged() && (
        (
          hasPermission('projects.update')
          && operationalProjectFieldsOnly()
        )
        || (
          hasPermission('projects.payments')
          && paymentProjectFieldsOnly()
        )
      );
      allow delete: if hasPermission('projects.delete');
    }

    match /inventory/{itemId} {
      allow read: if hasPermission('inventory.read');
      allow create, update, delete: if hasPermission('inventory.write');
    }

    match /inverters/{itemId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('equipment.write');
    }

    match /batteries/{itemId} {
      allow read: if true;
      allow create, update, delete: if hasPermission('equipment.write');
    }

    match /auditLogs/{auditId} {
      allow read: if hasPermission('audit.read');
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
