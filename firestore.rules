rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentRole() {
      return userExists() ? currentUserProfile().role : 'customer';
    }

    function tokenHasAuthTime() {
      return signedIn() && request.auth.token.auth_time is int;
    }

    function hasRevocationBoundary() {
      return userExists()
        && 'tokensValidAfterSeconds' in currentUserProfile()
        && currentUserProfile().tokensValidAfterSeconds is int;
    }

    function unrevokedSession() {
      return tokenHasAuthTime() && (
        !hasRevocationBoundary()
        || request.auth.token.auth_time > currentUserProfile().tokensValidAfterSeconds
      );
    }

    function privilegedRole() {
      return currentRole() in ['admin', 'analyst', 'inventory_manager', 'project_manager'];
    }

    function activeSession() {
      return unrevokedSession() && (
        !privilegedRole()
        || request.time.toMillis() - (request.auth.token.auth_time * 1000) < 28800000
      );
    }

    function hasPermission(permission) {
      return activeSession() && (
        currentRole() == 'admin'
        || (
          currentRole() == 'analyst'
          && permission in [
            'dashboard.access',
            'projects.read',
            'inventory.read',
            'equipment.read',
            'analytics.read'
          ]
        )
        || (
          currentRole() == 'inventory_manager'
          && permission in [
            'dashboard.access',
            'inventory.read',
            'inventory.write',
            'equipment.read',
            'equipment.write'
          ]
        )
        || (
          currentRole() == 'project_manager'
          && permission in [
            'dashboard.access',
            'messages.read',
            'messages.manage',
            'projects.read',
            'projects.create',
            'projects.update',
            'projects.payments',
            'projects.documents',
            'notifications.send'
          ]
        )
      );
    }

    function isOwner(userId) {
      return activeSession() && request.auth.uid == userId;
    }

    function validInventoryItem(itemId) {
      return request.resource.data.itemId == itemId
        && request.resource.data.type in ['panel', 'inverter', 'battery', 'wiring', 'mounting', 'other']
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.sku is string
        && request.resource.data.quantity is int
        && request.resource.data.quantity >= 0
        && request.resource.data.reorderPoint is int
        && request.resource.data.reorderPoint >= 0
        && request.resource.data.targetStock is int
        && request.resource.data.targetStock >= request.resource.data.reorderPoint
        && request.resource.data.leadTimeDays is int
        && request.resource.data.leadTimeDays > 0
        && request.resource.data.costPrice is number
        && request.resource.data.costPrice >= 0
        && request.resource.data.sellingPrice is number
        && request.resource.data.sellingPrice >= 0
        && request.resource.data.activeForCalculator is bool
        && request.resource.data.discontinued is bool
        && request.resource.data.specs is map;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || hasPermission('users.read');
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.role == 'customer';
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email', 'displayName', 'updatedAt'
        ]);
      allow delete: if false;
    }

    match /projects/{projectId} {
      // Customer reads go through getMyProjects, which applies a strict allowlist.
      allow read: if hasPermission('projects.read');

      // The createQuotation Netlify function creates projects. All later editing,
      // status, payment and deletion workflows are also authenticated functions.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /projectOperations/{projectId} {
      // BOM, costs, stock planning, activity and internal notes are staff-only.
      allow read: if hasPermission('projects.read');
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /projectNotifications/{notificationId} {
      allow read, write: if false;
    }

    match /deletedProjects/{projectId} {
      allow read, write: if false;
    }

    match /enquiries/{enquiryId} {
      // Public submission and staff inbox actions are handled only by validated
      // Netlify functions. No browser receives direct Firestore access.
      allow read, write: if false;
    }

    match /inventory/{itemId} {
      allow read: if hasPermission('inventory.read');
      allow create, update: if hasPermission('inventory.write') && validInventoryItem(itemId);
      allow delete: if hasPermission('inventory.write');
    }

    match /recommendations/{recommendationId} {
      allow read, write: if false;
    }

    match /inverters/{itemId} {
      allow read, write: if false;
    }

    match /batteries/{itemId} {
      allow read, write: if false;
    }

    match /auditLogs/{auditId} {
      allow read: if hasPermission('audit.read');
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
